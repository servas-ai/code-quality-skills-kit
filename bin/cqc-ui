.pill.done{background:var(--gn);color:#000}
.pill.skip{background:var(--bd);color:var(--muted)}
.pill.fail{background:var(--rd);color:#fff}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
