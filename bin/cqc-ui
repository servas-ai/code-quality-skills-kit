#!/usr/bin/env bash
# cqc-ui — local web UI to monitor cqc runs
# Spawns a tiny Python HTTP server on http://localhost:7331
# Auto-refreshes every 3s. Reads audit-reports/ directly. No deps.
#
# Usage:  cqc-ui              # serve current dir's audit-reports/
#         cqc-ui /path/repo   # serve a specific repo's audit-reports/
#         cqc-ui --port 8080  # custom port

set -euo pipefail
umask 077

PORT="${CQC_UI_PORT:-7331}"
TARGET="${1:-.}"

while [ "${1:-}" != "" ]; do
  case "$1" in
    --port)  PORT="$2"; shift ;;
    --port=*) PORT="${1#--port=}" ;;
    -h|--help)
      cat <<HELP
cqc-ui — local web UI for cqc

Usage:
  cqc-ui                # serve cwd's audit-reports/
  cqc-ui /path/to/repo  # serve a specific repo
  cqc-ui --port 8080    # custom port (default 7331)
HELP
      exit 0 ;;
    *) [ -d "$1" ] && TARGET="$1" ;;
  esac
  shift
done

cd "$TARGET"
ABS=$(pwd -P)

if ! command -v python3 >/dev/null; then
  echo "❌ python3 required (for the embedded server)" >&2; exit 1
fi

# Generate the index.html dynamically (single file, all-in-one)
TMPDIR=$(mktemp -d) && trap "rm -rf $TMPDIR" EXIT
HTML="$TMPDIR/index.html"

cat > "$HTML" <<'HTMLEOF'
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>cqc · runs monitor</title>
<style>
:root{--bg:#0a0d12;--card:#14181f;--bd:#2a2f3b;--fg:#e6e8eb;--muted:#8b93a1;--cy:#00d9ff;--gn:#4ade80;--am:#ffc857;--rd:#ff5566}
*,*::before,*::after{box-sizing:border-box}
body{font-family:'JetBrains Mono','SF Mono',Consolas,monospace;background:var(--bg);color:var(--fg);margin:0;padding:24px;line-height:1.5}
h1{font-size:20px;margin:0 0 8px;letter-spacing:-.01em}
.sub{color:var(--muted);font-size:12px;margin-bottom:24px}
.row{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:24px}
.kpi{background:var(--card);border:1px solid var(--bd);border-radius:8px;padding:14px}
