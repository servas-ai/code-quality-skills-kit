#!/usr/bin/env bash
# cqc-ui — local live dashboard for code-quality-skills-kit
# Spawns a Python HTTP server with SSE on http://localhost:7331.
#
# Usage:  cqc-ui                   # serve cwd
#         cqc-ui /path/to/repo     # serve a specific repo
#         cqc-ui --port 8080       # custom port

set -euo pipefail
umask 077

PORT="${CQC_UI_PORT:-4020}"
TARGET="."
VERSION="v3.14"
BIND="${CQC_UI_BIND:-0.0.0.0}"   # bind to all interfaces incl. Tailscale

while [ "${1:-}" != "" ]; do
  case "$1" in
    --port)   PORT="$2"; shift ;;
    --port=*) PORT="${1#--port=}" ;;
    -h|--help)
      cat <<HELP
cqc-ui — local live dashboard for cqc

Usage:
  cqc-ui                # serve cwd
  cqc-ui /path/to/repo  # serve a specific repo
  cqc-ui --port 8080    # custom port (default 7331)

Environment:
  CQC_UI_PORT           override default port
HELP
      exit 0 ;;
    --*) echo "Unknown flag: $1" >&2; exit 1 ;;
    *)   [ -d "$1" ] && TARGET="$1" ;;
  esac
  shift
done

cd "$TARGET"
ABS=$(pwd -P)

if ! command -v python3 >/dev/null 2>&1; then
  echo "cqc-ui: python3 is required" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
SERVER="$SCRIPT_DIR/cqc-ui.py"

if [ ! -f "$SERVER" ]; then
  echo "cqc-ui: missing $SERVER" >&2
  exit 1
fi

export CQC_ROOT="$ABS"
export CQC_PORT="$PORT"
export CQC_BIND="$BIND"
export CQC_VERSION="$VERSION"

# Pre-flight: detect Tailscale and print all reachable URLs
if command -v tailscale >/dev/null 2>&1; then
  TS_HOST=$(tailscale status --self --json 2>/dev/null | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("Self",{}).get("DNSName","").rstrip("."))' 2>/dev/null)
  TS_IP=$(tailscale ip -4 2>/dev/null | head -1)
fi

cat <<URLS

  cqc-ui $VERSION · serving $ABS/audit-reports/

  ▸ Local:      http://localhost:$PORT
  ▸ LAN:        http://$(hostname -I | awk '{print $1}'):$PORT
${TS_HOST:+  ▸ Tailscale:  http://${TS_HOST}:$PORT}
${TS_IP:+  ▸ Tailscale-IP: http://${TS_IP}:$PORT}

  Press Ctrl-C to stop.

URLS

exec python3 "$SERVER"
