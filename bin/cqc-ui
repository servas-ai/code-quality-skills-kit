<script>
const root='__CWD__';
const fmt=(n)=>n>=1000?(n/1000).toFixed(1)+'K':n;
const ago=(secs)=>{
  if(secs<60)return secs+'s ago';
  if(secs<3600)return Math.floor(secs/60)+'m ago';
  if(secs<86400)return Math.floor(secs/3600)+'h ago';
  return Math.floor(secs/86400)+'d ago';
};

async function fetchJSON(url){
  try{const r=await fetch(url);if(!r.ok)return null;return await r.json();}catch(e){return null;}
}
async function fetchText(url){
  try{const r=await fetch(url);if(!r.ok)return null;return await r.text();}catch(e){return null;}
}

async function refresh(){
  document.getElementById('ts').textContent=new Date().toLocaleTimeString();

  const idx=await fetchJSON('/api/index');
  if(!idx){
    document.getElementById('runs').innerHTML='<div class="empty">No audit-reports/ folder found in '+root+'</div>';
    return;
  }

  // KPIs
  const kpiEl=document.getElementById('kpi');
  const totalRuns=idx.runs.length;
  const latest=idx.runs[0]||null;
  let totalFindings=0,totalCrit=0;
  if(latest&&latest.counts){
    totalFindings=(latest.counts.c||0)+(latest.counts.h||0)+(latest.counts.m||0)+(latest.counts.l||0);
    totalCrit=latest.counts.c||0;
  }
  kpiEl.innerHTML=`
    <div class="kpi cy"><div class="l">Runs</div><div class="v">${totalRuns}</div></div>
    <div class="kpi gn"><div class="l">Latest score</div><div class="v">${latest?.overall??'—'}/100</div></div>
    <div class="kpi ${totalCrit>0?'rd':'gn'}"><div class="l">Critical</div><div class="v">${totalCrit}</div></div>
    <div class="kpi ${latest?.coverage>=99?'gn':'am'}"><div class="l">Coverage</div><div class="v">${latest?.coverage??0}%</div></div>
  `;

  // Runs table
  let runsHTML='<table><thead><tr><th>Run ID</th><th>Phase</th><th>Agents</th><th>Findings</th><th>Score</th><th>Started</th></tr></thead><tbody>';
  if(!idx.runs.length){
    runsHTML='<div class="empty">No runs yet. Run <code>cqc</code> to create one.</div>';
  }else{
    for(const r of idx.runs){
      const c=r.counts||{};
      const f=`<span class="sev-c">${c.c||0}c</span> <span class="sev-h">${c.h||0}h</span> <span class="sev-m">${c.m||0}m</span> <span class="sev-l">${c.l||0}l</span>`;
      const phaseClass={done:'done',dispatching:'run',auditing:'run',failed:'fail'}[r.phase]||'skip';
      const agents=Object.entries(r.agents||{}).map(([k,v])=>{
        const cls={done:'done',skipped:'skip',failed:'fail',in_progress:'run',claimed:'run'}[v.status]||'skip';
        return `<span class="pill ${cls}">${k}</span>`;
      }).join('');
      runsHTML+=`<tr><td><code><a href="#${r.id}">${r.id}</a></code></td><td><span class="pill ${phaseClass}">${r.phase||'?'}</span></td><td>${agents||'—'}</td><td>${f}</td><td>${r.overall??'—'}</td><td>${r.started_ago||'—'}</td></tr>`;
    }
    runsHTML+='</tbody></table>';
  }
  document.getElementById('runs').innerHTML=runsHTML;

  // Findings (latest run)
  if(latest&&latest.findings&&latest.findings.length){
    let html='<table><thead><tr><th>ID</th><th>Sev</th><th>Dim</th><th>File:Line</th><th>Rule</th><th>Message</th></tr></thead><tbody>';
    for(const f of latest.findings.slice(0,30)){
      html+=`<tr><td><code>${f.id||'—'}</code></td><td><span class="sev-${f.sev}">${(f.sev||'?').toUpperCase()}</span></td><td>${f.dim}</td><td><code>${f.file}:${f.line}</code></td><td>${f.rule||'—'}</td><td>${f.msg||''}</td></tr>`;
    }
    html+='</tbody></table>';
    if(latest.findings.length>30)html+=`<div class="sub">Showing 30 of ${latest.findings.length}</div>`;
    document.getElementById('findings').innerHTML=html;
  }else{
    document.getElementById('findings').innerHTML='<div class="empty">No findings in latest run</div>';
  }

  // CLI status
  const clis=await fetchJSON('/api/clis');
  if(clis){
    let html='<table><thead><tr><th>CLI</th><th>Status</th><th>Version</th><th>Plan</th><th>Account</th></tr></thead><tbody>';
    for(const c of clis){
      const dot=c.installed?'<span class="pill done">●</span>':'<span class="pill skip">○</span>';
      html+=`<tr><td><strong>${c.name}</strong></td><td>${dot} ${c.installed?'installed':'not detected'}</td><td><code>${c.version||'—'}</code></td><td>${c.plan||'—'}</td><td><code>${c.account||'—'}</code></td></tr>`;
    }
    html+='</tbody></table>';
    document.getElementById('clis').innerHTML=html;
  }
}

refresh();
setInterval(refresh,3000);
</script>
</body>
</html>
HTMLEOF

# Substitute __CWD__
sed -i "s|__CWD__|$ABS|g" "$HTML"

# Generate the Python server (with API endpoints)
cat > "$TMPDIR/server.py" <<PYEOF
#!/usr/bin/env python3
"""cqc-ui server — serves /api/* JSON + index.html"""
import http.server, socketserver, json, os, glob, time, subprocess, re, sys
from datetime import datetime, timezone

ROOT = "$ABS"
HTML = "$HTML"
PORT = $PORT

def time_ago(iso):
    try:
        if not iso: return None
        t = datetime.fromisoformat(iso.replace("Z","+00:00"))
        delta = (datetime.now(timezone.utc) - t).total_seconds()
        if delta < 60: return f"{int(delta)}s ago"
        if delta < 3600: return f"{int(delta/60)}m ago"
        if delta < 86400: return f"{int(delta/3600)}h ago"
        return f"{int(delta/86400)}d ago"
    except: return None

def load_run(run_dir):
    out = {"id": os.path.basename(run_dir), "phase": "?", "counts": {}, "agents": {}, "findings": []}
    rj = os.path.join(run_dir, "_run.json")
    if os.path.isfile(rj):
        try:
            with open(rj) as f: data = json.load(f)
            out["phase"] = data.get("phase") or "done"
            out["overall"] = data.get("overall")
            out["agents"] = data.get("agents", {})
            out["coverage"] = round((data.get("stats", {}).get("coverage_pct", 0)) or 0)
            out["started_ago"] = time_ago(data.get("started_at", ""))
        except Exception as e: pass
    fj = os.path.join(run_dir, "_findings.jsonl")
    if os.path.isfile(fj):
        try:
            with open(fj) as f:
                for line in f:
                    line = line.strip()
                    if not line or not line.startswith("{"): continue
                    try: out["findings"].append(json.loads(line))
                    except: continue
            counts = {"c":0,"h":0,"m":0,"l":0}
            for f in out["findings"]: counts[f.get("sev","l")] = counts.get(f.get("sev","l"),0)+1
            out["counts"] = counts
        except: pass
    return out

def cli_status():
    out = []
    for name, pkg in [("claude","@anthropic-ai/claude-code"),("gemini","@google/gemini-cli"),
                      ("opencode","opencode-ai"),("codex","@openai/codex")]:
        try:
            ver = subprocess.run([name,"--version"], capture_output=True, text=True, timeout=3)
            v = re.search(r"(\d+\.\d+\.\d+)", ver.stdout + ver.stderr)
            installed = ver.returncode == 0
        except: installed = False; v = None
        plan = "—"; acct = "—"
        if name == "claude" and os.path.isfile(os.path.expanduser("~/.claude/auth.json")):
            try:
                with open(os.path.expanduser("~/.claude/auth.json")) as f: a = json.load(f)
                plan = a.get("subscription_type") or a.get("plan") or "api"
                em = a.get("email","")
                acct = em[:1]+"***@***" if em else "—"
            except: pass
        elif name == "codex" and os.path.isfile(os.path.expanduser("~/.codex/auth.json")):
            try:
                with open(os.path.expanduser("~/.codex/auth.json")) as f: a = json.load(f)
                plan = a.get("auth_mode","chatgpt")
            except: pass
        elif name == "gemini" and os.path.isfile(os.path.expanduser("~/.gemini/google_accounts.json")):
            try:
                with open(os.path.expanduser("~/.gemini/google_accounts.json")) as f: a = json.load(f)
                em = a.get("active","")
                acct = em[:1]+"***@***" if em else "—"
                plan = "free"
            except: pass
        out.append({"name":name,"installed":installed,"version":v.group(1) if v else None,"plan":plan,"account":acct})
    return out

class H(http.server.SimpleHTTPRequestHandler):
    def log_message(self, *a): pass
    def do_GET(self):
        if self.path in ("/", "/index.html"):
            with open(HTML, "rb") as f: data = f.read()
            self.send_response(200)
            self.send_header("Content-Type","text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
            return
        if self.path == "/api/index":
            runs_dir = os.path.join(ROOT, "audit-reports")
            runs = []
            if os.path.isdir(runs_dir):
                for d in sorted(os.listdir(runs_dir), reverse=True):
                    full = os.path.join(runs_dir, d)
                    if os.path.isdir(full): runs.append(load_run(full))
            data = json.dumps({"runs": runs[:20]}).encode()
            self.send_response(200)
            self.send_header("Content-Type","application/json")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
            return
        if self.path == "/api/clis":
            data = json.dumps(cli_status()).encode()
            self.send_response(200)
            self.send_header("Content-Type","application/json")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
            return
        self.send_response(404); self.end_headers()

with socketserver.TCPServer(("127.0.0.1", PORT), H) as httpd:
    httpd.allow_reuse_address = True
    print(f"\n  \033[36m▸\033[0m cqc-ui serving \033[1m{ROOT}/audit-reports/\033[0m")
    print(f"  \033[36m▸\033[0m open \033[1mhttp://localhost:{PORT}\033[0m")
    print(f"  \033[36m▸\033[0m Ctrl-C to stop\n")
    try: httpd.serve_forever()
    except KeyboardInterrupt: print("\n  stopped.")
PYEOF

python3 "$TMPDIR/server.py"
