#!/usr/bin/env bash
# cqc-parallel — fan out audit to all 4 CLIs simultaneously, fully autonomous
# Each CLI gets its skill slice + permission-bypass flag + the kit prompt
#
# Usage:  cqc-parallel              # all detected CLIs, scope = whole repo
#         cqc-parallel src/lib      # scope to path
#         cqc-parallel --clis=gemini,codex   # restrict
#
# Permission flags (each CLI's "skip-prompts" mode):
#   claude   → --dangerously-skip-permissions
#   gemini   → --yolo
#   codex    → --dangerously-bypass-approvals-and-sandbox
#   opencode → --dangerously-skip-permissions
#
# Each CLI runs in background; outputs land in audit-reports/<RUN_ID>/<cli>.log
# Watchdog: 5min/agent timeout. On hang/crash → commit partial output, dispatch next.

set -euo pipefail
umask 077

SCOPE="${1:-.}"
[[ "$SCOPE" == --* ]] && SCOPE="."

ENABLED_CLIS=""
TIMEOUT="${CQC_TIMEOUT:-300}"   # 5 min per agent
while [ "${1:-}" != "" ]; do
  case "$1" in
    --clis=*)    ENABLED_CLIS="${1#--clis=}" ;;
    --timeout=*) TIMEOUT="${1#--timeout=}" ;;
    -h|--help)
      cat <<HELP
cqc-parallel — fan out audit to all CLIs simultaneously

Usage:
  cqc-parallel [scope]              # default: whole repo
  cqc-parallel src/lib              # scope to path
  cqc-parallel --clis=gemini,codex  # only these CLIs
  cqc-parallel --timeout=600        # 10 min per agent

Each CLI runs autonomously (skip-permissions flag). On hang/crash, partial
output is committed to _findings.jsonl and the next agent picks up.
HELP
      exit 0 ;;
    --*) ;;  # already handled
    *) [ "$SCOPE" = "." ] && SCOPE="$1" ;;
  esac
  shift
done

# Colors
if [ -t 1 ]; then
  C_CYAN=$'\033[36m'; C_GREEN=$'\033[32m'; C_AMBER=$'\033[33m'; C_RED=$'\033[31m'
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'; C_RST=$'\033[0m'
else
  C_CYAN=""; C_GREEN=""; C_AMBER=""; C_RED=""; C_BOLD=""; C_DIM=""; C_RST=""
fi

# ─── Detect CLIs + skill assignment ───────────────────────────────
declare -A AVAILABLE=()
[ -x "$(command -v claude)"   ] && AVAILABLE[claude]=1
[ -x "$(command -v gemini)"   ] && AVAILABLE[gemini]=1
[ -x "$(command -v codex)"    ] && AVAILABLE[codex]=1
[ -x "$(command -v opencode)" ] && AVAILABLE[opencode]=1

# Skills per CLI (matches cqc dispatch matrix)
declare -A SKILLS=(
  [claude]="d4 d6 d13"
  [gemini]="d12 d8 d9"
  [opencode]="d1 d3 d11 d14 d15"
  [codex]="d2 d5 d7 d10"
)

# Filter by --clis= flag
if [ -n "$ENABLED_CLIS" ]; then
  declare -A NEW_AVAIL=()
  for cli in $(echo "$ENABLED_CLIS" | tr ',' ' '); do
    [ -n "${AVAILABLE[$cli]:-}" ] && NEW_AVAIL[$cli]=1
  done
  AVAILABLE=()
  for k in "${!NEW_AVAIL[@]}"; do AVAILABLE[$k]=1; done
fi

if [ "${#AVAILABLE[@]}" -eq 0 ]; then
  echo "${C_RED}❌ No CLIs available${C_RST}"; exit 1
fi

# ─── Setup run dir ────────────────────────────────────────────────
RUN_ID="$(date -u +%Y-%m-%d)__parallel-$(date +%H%M%S)"
RUN_DIR="audit-reports/$RUN_ID"
mkdir -p "$RUN_DIR/logs"
touch "$RUN_DIR/_findings.jsonl"

cat > "$RUN_DIR/_run.json" <<EOF
{"run_id":"$RUN_ID","scope":"$SCOPE","started_at":"$(date -u +%Y-%m-%dT%H:%M:%SZ)","phase":"dispatching","agents":{}}
EOF

echo "${C_BOLD}╭─────────────────────────────────────────────────────────────╮${C_RST}"
echo "${C_BOLD}│${C_RST} ${C_CYAN}cqc-parallel${C_RST} · scope: ${C_CYAN}$SCOPE${C_RST}"
echo "${C_BOLD}│${C_RST} run-id: ${C_DIM}$RUN_ID${C_RST}"
echo "${C_BOLD}│${C_RST} CLIs: ${C_GREEN}${!AVAILABLE[*]}${C_RST} · timeout/agent: ${TIMEOUT}s"
echo "${C_BOLD}╰─────────────────────────────────────────────────────────────╯${C_RST}"
echo ""

# ─── Build the skill prompt each CLI receives ─────────────────────
build_prompt() {
  local cli="$1"
  local skills="${SKILLS[$cli]}"
  cat <<PROMPT
You are running sub-skills [$skills] from code-quality-skills-kit on behalf of CLI=$cli.

Working directory: $(pwd)
Scope: $SCOPE
Run-id: $RUN_ID
Findings file (append JSONL): $RUN_DIR/_findings.jsonl
Master prompt: $(pwd)/code-quality-checker.md

For EACH skill assigned to you ($skills), execute the AUDIT steps from
'§ Skill kit:<skill-id>' in the master prompt. Use only rg/git/jq/wc tools.

ID prefix: ALWAYS prefix your finding IDs with "$cli-" (e.g. ${cli}-C1, ${cli}-H1).
This prevents collisions with other CLIs running in parallel.

For each finding append ONE LINE of NDJSON to $RUN_DIR/_findings.jsonl:
{"id":"$cli-C1","sev":"c","dim":"d4","file":"<path>","line":N,"rule":"<rule>","msg":"<≤80c>","conf":1.0,"tags":["..."],"excerpt":"<≤72c, comments stripped>"}

When done, write ONE LINE to $RUN_DIR/logs/$cli.done with:
  done|<skills_completed>|<finding_count>|<elapsed_seconds>

NO source edits. READ-ONLY audit. Output a 3-line summary at the end:
1. Skills completed
2. Finding counts (c/h/m/l)
3. Top finding as compact citation @file:line  excerpt
PROMPT
}

# ─── Spawn each CLI in background ─────────────────────────────────
declare -A PIDS=()
declare -A START=()

spawn_cli() {
  local cli="$1"
  local prompt="$(build_prompt $cli)"
  local log="$RUN_DIR/logs/${cli}.log"
  local cmd

  case "$cli" in
    claude)
      cmd=(claude --print --dangerously-skip-permissions --model claude-opus-4-7 "$prompt") ;;
    gemini)
      cmd=(gemini --yolo --approval-mode yolo -m gemini-3.1-pro-preview -p "$prompt") ;;
    codex)
      cmd=(codex exec --dangerously-bypass-approvals-and-sandbox "$prompt") ;;
    opencode)
      cmd=(opencode run --dangerously-skip-permissions "$prompt") ;;
  esac

  echo "${C_DIM}  spawning $cli (pid pending)…${C_RST}"
  ( timeout --kill-after=10 "$TIMEOUT" "${cmd[@]}" > "$log" 2>&1
    EXIT=$?
    if [ $EXIT -eq 0 ]; then
      echo "ok|$cli|$EXIT" > "$RUN_DIR/logs/${cli}.status"
    elif [ $EXIT -eq 124 ]; then
      echo "timeout|$cli|$EXIT" > "$RUN_DIR/logs/${cli}.status"
    else
      echo "crash|$cli|$EXIT" > "$RUN_DIR/logs/${cli}.status"
    fi
  ) &
  PIDS[$cli]=$!
  START[$cli]=$(date +%s)
}

for cli in "${!AVAILABLE[@]}"; do
  spawn_cli "$cli"
done

echo ""
echo "${C_BOLD}▸ All ${#PIDS[@]} CLIs spawned in parallel${C_RST}"
echo "${C_DIM}  PIDs: ${PIDS[*]}${C_RST}"
echo ""

# ─── Live status watchdog ─────────────────────────────────────────
SECONDS=0
echo "${C_BOLD}▸ Watching (refresh every 10s)…${C_RST}"
echo ""

while true; do
  active=0
  status_line=""
  for cli in "${!PIDS[@]}"; do
    if kill -0 "${PIDS[$cli]}" 2>/dev/null; then
      elapsed=$(( $(date +%s) - ${START[$cli]} ))
      status_line+="${C_AMBER}${cli}⏳${elapsed}s${C_RST} "
      active=$((active+1))
    elif [ -f "$RUN_DIR/logs/${cli}.status" ]; then
      sts=$(cut -d'|' -f1 < "$RUN_DIR/logs/${cli}.status")
      case "$sts" in
        ok)      status_line+="${C_GREEN}${cli}✓${C_RST} " ;;
        timeout) status_line+="${C_RED}${cli}⏰${C_RST} " ;;
        crash)   status_line+="${C_RED}${cli}❌${C_RST} " ;;
      esac
    fi
  done
  fcount=$(wc -l < "$RUN_DIR/_findings.jsonl" 2>/dev/null || echo 0)
  printf "\r  [%4ds] %s findings: %s" "$SECONDS" "$status_line" "$fcount"
  [ $active -eq 0 ] && break
  sleep 10
done
echo ""
echo ""

# ─── Aggregate ────────────────────────────────────────────────────
echo "${C_BOLD}▸ All agents done · aggregating${C_RST}"
echo ""

FF="$RUN_DIR/_findings.jsonl"
[ ! -f "$FF" ] && touch "$FF"
C=$(grep -cE '"sev"\s*:\s*"c"' "$FF" 2>/dev/null | head -1 || true); C="${C:-0}"
H=$(grep -cE '"sev"\s*:\s*"h"' "$FF" 2>/dev/null | head -1 || true); H="${H:-0}"
M=$(grep -cE '"sev"\s*:\s*"m"' "$FF" 2>/dev/null | head -1 || true); M="${M:-0}"
L=$(grep -cE '"sev"\s*:\s*"l"' "$FF" 2>/dev/null | head -1 || true); L="${L:-0}"
# Strip newlines defensively
C="${C//$'\n'/}"; H="${H//$'\n'/}"; M="${M//$'\n'/}"; L="${L//$'\n'/}"
TOT=$((C+H+M+L))

# Build agent statuses for _run.json
AGENTS_JSON="{}"
for cli in "${!AVAILABLE[@]}"; do
  if [ -f "$RUN_DIR/logs/${cli}.status" ]; then
    SLINE=$(cat "$RUN_DIR/logs/${cli}.status")
    STATE=$(echo "$SLINE" | cut -d'|' -f1)
    EXIT=$(echo "$SLINE" | cut -d'|' -f3)
    case "$STATE" in
      ok)      STATUS="done"     ;;
      timeout) STATUS="timeout"  ;;
      crash)   STATUS="failed"   ;;
      *)       STATUS="unknown"  ;;
    esac
    AGENTS_JSON=$(echo "$AGENTS_JSON" | jq --arg c "$cli" --arg s "$STATUS" --arg e "$EXIT" \
      '. + {($c): {status:$s, exit_code:($e|tonumber? // 0)}}')
  fi
done

# Update _run.json
jq --arg now "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson a "$AGENTS_JSON" \
  --argjson c $C --argjson h $H --argjson m $M --argjson l $L \
  '.phase = "done" | .completed_at = $now | .agents = $a |
   .stats = {findings: {c:$c, h:$h, m:$m, l:$l, total: ($c+$h+$m+$l)}}' \
  "$RUN_DIR/_run.json" > "$RUN_DIR/_run.json.tmp" && mv "$RUN_DIR/_run.json.tmp" "$RUN_DIR/_run.json"

# ─── Final summary ────────────────────────────────────────────────
echo "${C_BOLD}╭─ Final ─────────────────────────────────────────────────────╮${C_RST}"
printf "${C_BOLD}│${C_RST} run-id:   %s\n" "$RUN_ID"
printf "${C_BOLD}│${C_RST} findings: ${C_RED}%d${C_RST}c ${C_AMBER}%d${C_RST}h ${C_AMBER}%d${C_RST}m ${C_GREEN}%d${C_RST}l (total %d)\n" "$C" "$H" "$M" "$L" "$TOT"
printf "${C_BOLD}│${C_RST} duration: %ds\n" "$SECONDS"
echo "${C_BOLD}│${C_RST} per-CLI:"
for cli in "${!AVAILABLE[@]}"; do
  if [ -f "$RUN_DIR/logs/${cli}.status" ]; then
    SLINE=$(cat "$RUN_DIR/logs/${cli}.status")
    printf "${C_BOLD}│${C_RST}   %-9s %s\n" "$cli" "$SLINE"
  fi
done
echo "${C_BOLD}│${C_RST}"
printf "${C_BOLD}│${C_RST} reports:  %s/\n" "$RUN_DIR"
echo "${C_BOLD}╰─────────────────────────────────────────────────────────────╯${C_RST}"

# ─── Re-dispatch failed agents (commit partial + retry once) ──────
NEEDS_RETRY=()
for cli in "${!AVAILABLE[@]}"; do
  [ ! -f "$RUN_DIR/logs/${cli}.status" ] && continue
  SLINE=$(cat "$RUN_DIR/logs/${cli}.status")
  STATE=$(echo "$SLINE" | cut -d'|' -f1)
  if [ "$STATE" = "timeout" ] || [ "$STATE" = "crash" ]; then
    NEEDS_RETRY+=("$cli")
  fi
done

if [ ${#NEEDS_RETRY[@]} -gt 0 ]; then
  echo ""
  echo "${C_AMBER}▸ Retry needed for: ${NEEDS_RETRY[*]}${C_RST}"
  echo "${C_DIM}  partial findings already committed to _findings.jsonl${C_RST}"
  echo "${C_DIM}  re-run: cqc-parallel --clis=$(IFS=,; echo "${NEEDS_RETRY[*]}") $SCOPE${C_RST}"
fi

echo ""
echo "${C_GREEN}✓ done${C_RST}"
