#!/usr/bin/env bash
# cqc-orchestrate v4 — thin wrapper around `mco review`.
# Reads cqc.config.yaml (or cqc-budget.yaml / ~/.cqc/budget.json) for caps_pct,
# probes quota via `mco doctor --json`, excludes files from prefilter clean-files.txt.
# Usage: cqc-orchestrate [SCOPE] [--max-parallel=N] [--plan-only]
#        [--prefilter-dir=PATH] [--include-claude] [--stall-timeout=S] [--budget=PATH]
# Env: CQC_TIMEOUT (legacy stall-timeout, default 240); MCO_BIN (default: mco)

set -euo pipefail
umask 077

# ─── Defaults ─────────────────────────────────────────────────────
SCOPE="."
MAX_PARALLEL=10
PLAN_ONLY=0
INCLUDE_CLAUDE=0
STALL_TIMEOUT="${CQC_TIMEOUT:-240}"
BUDGET_FILE=""
PREFILTER_DIR=""
MCO_BIN="${MCO_BIN:-mco}"

# ─── Args ─────────────────────────────────────────────────────────
while [ "${1:-}" != "" ]; do
  case "$1" in
    --max-parallel=*)    MAX_PARALLEL="${1#--max-parallel=}" ;;
    --max-parallel)      shift; MAX_PARALLEL="$1" ;;
    --stall-timeout=*)   STALL_TIMEOUT="${1#--stall-timeout=}" ;;
    --stall-timeout)     shift; STALL_TIMEOUT="$1" ;;
    --plan-only)         PLAN_ONLY=1 ;;
    --include-claude)    INCLUDE_CLAUDE=1 ;;
    --budget=*)          BUDGET_FILE="${1#--budget=}" ;;
    --prefilter-dir=*)   PREFILTER_DIR="${1#--prefilter-dir=}" ;;
    --scope=*)           SCOPE="${1#--scope=}" ;;
    --scope)             shift; SCOPE="$1" ;;
    --timeout=*)         STALL_TIMEOUT="${1#--timeout=}" ;;  # legacy
    --shard=*|--shard)   ;; # legacy: MCO controls sharding
    -h|--help) sed -n '2,7p' "$0"; exit 0 ;;
    --*) ;;
    *) [ "$SCOPE" = "." ] && SCOPE="$1" ;;
  esac
  shift
done

if [ -t 1 ]; then
  C_CYAN=$'\033[36m'; C_GREEN=$'\033[32m'; C_AMBER=$'\033[33m'; C_RED=$'\033[31m'
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'; C_RST=$'\033[0m'
else C_CYAN=""; C_GREEN=""; C_AMBER=""; C_RED=""; C_BOLD=""; C_DIM=""; C_RST=""; fi

# ─── Resolve budget file (YAML or JSON) ───────────────────────────
if [ -z "$BUDGET_FILE" ]; then
  if   [ -f "./cqc-budget.yaml"  ]; then BUDGET_FILE="./cqc-budget.yaml"
  elif [ -f "./cqc.config.yaml"  ]; then BUDGET_FILE="./cqc.config.yaml"
  elif [ -f "$HOME/.cqc/budget.json" ]; then BUDGET_FILE="$HOME/.cqc/budget.json"
  else
    echo "${C_RED}❌ No budget file found (cqc-budget.yaml | cqc.config.yaml | ~/.cqc/budget.json)${C_RST}" >&2
    exit 1
  fi
fi

# Normalise budget → JSON via python (handles YAML & JSON).
read_budget() {
  python3 - "$BUDGET_FILE" <<'PY'
import json, sys, re
p = sys.argv[1]
data = open(p).read()
try:
    cfg = json.loads(data)
except Exception:
    try:
        import yaml
    except ImportError:
        sys.stderr.write("⚠ Budget file is YAML but PyYAML missing. Install: pip install pyyaml — OR use ~/.cqc/budget.json (JSON).\n")
        sys.exit(2)
    cfg = yaml.safe_load(data) or {}
caps = cfg.get("caps_pct") or {}
# Accept "75%" strings from cqc-budget.yaml's budget_thresholds form too.
if not caps and "budget_thresholds" in cfg:
    for k, v in (cfg["budget_thresholds"] or {}).items():
        m = re.match(r"\s*(\d+)\s*%?\s*", str(v))
        caps[k] = int(m.group(1)) if m else 0
print(json.dumps({"caps_pct": caps}))
PY
}
BUDGET_JSON="$(read_budget)"
cap_for() { echo "$BUDGET_JSON" | jq -r --arg c "$1" '.caps_pct[$c] // 0'; }

# ─── Probe live quota via mco doctor ──────────────────────────────
DOCTOR_JSON="$($MCO_BIN doctor --json 2>/dev/null || echo '{}')"
provider_ready() { echo "$DOCTOR_JSON" | jq -e -r --arg p "$1" '.providers[$p].ready // false' >/dev/null 2>&1; }

# Optional: percent-used per CLI from ~/.cqc/usage.json
USAGE_FILE="$HOME/.cqc/usage.json"
used_pct() {
  [ -f "$USAGE_FILE" ] || { echo 0; return; }
  jq -r --arg c "$1" '(.by_cli[$c].used_pct // 0)' "$USAGE_FILE" 2>/dev/null | awk '{printf "%.0f", $1+0}'
}

# ─── Build provider list (cap > 0, ready, not over usage cap) ─────
declare -a PROVIDERS=()
declare -a SKIPPED=()
add_provider() {
  local p="$1" cap used
  cap="$(cap_for "$p")"
  used="$(used_pct "$p")"
  if [ "${cap:-0}" -le 0 ]; then SKIPPED+=("$p:cap=0"); return; fi
  if [ "$p" = "claude" ] && [ "$INCLUDE_CLAUDE" != "1" ]; then SKIPPED+=("$p:opt-in-required"); return; fi
  if ! provider_ready "$p"; then SKIPPED+=("$p:not-ready"); return; fi
  if [ "${used:-0}" -ge "${cap:-0}" ]; then SKIPPED+=("$p:used=${used}%≥cap=${cap}%"); return; fi
  PROVIDERS+=("$p")
}
for p in claude codex gemini opencode qwen; do add_provider "$p"; done

if [ "${#PROVIDERS[@]}" -eq 0 ]; then
  if [ "$PLAN_ONLY" = "1" ]; then
    echo "${C_AMBER}⚠ No eligible providers (plan-only mode). Skipped: ${SKIPPED[*]:-none}${C_RST}" >&2
    PROVIDERS=("(none-eligible)")
  else
    echo "${C_RED}❌ No eligible providers. Skipped: ${SKIPPED[*]:-none}${C_RST}" >&2; exit 1
  fi
fi
PROV_CSV="$(IFS=,; echo "${PROVIDERS[*]}")"

# ─── Resolve target paths and exclude clean files ────────────────
RUN_ID="$(date -u +%Y-%m-%d)__orch-$(date +%H%M%S)"
RUN_DIR="audit-reports/$RUN_ID"
mkdir -p "$RUN_DIR/mco-output"

# Auto-discover prefilter dir from latest audit-reports run if not given.
if [ -z "$PREFILTER_DIR" ]; then
  CAND="$(ls -1dt audit-reports/*/prefilter 2>/dev/null | head -n1 || true)"
  [ -n "$CAND" ] && [ -f "$CAND/clean-files.txt" ] && PREFILTER_DIR="$CAND"
fi

TARGETS="$SCOPE"
CLEAN_COUNT=0
if [ -n "$PREFILTER_DIR" ] && [ -f "$PREFILTER_DIR/clean-files.txt" ]; then
  CLEAN_COUNT=$(grep -c . "$PREFILTER_DIR/clean-files.txt" || true)
  # MCO --target-paths is positive-list only → build dirty-set = scope ∖ clean.
  if [ -d "$SCOPE" ]; then
    find "$SCOPE" -type f \( -name "*.ts" -o -name "*.tsx" -o -name "*.js" -o -name "*.jsx" \
      -o -name "*.py" -o -name "*.rs" -o -name "*.go" \) \
      -not -path "*/node_modules/*" -not -path "*/.git/*" -not -path "*/dist/*" \
      -not -path "*/audit-reports/*" 2>/dev/null | sort -u > "$RUN_DIR/_all.txt"
    sort -u "$PREFILTER_DIR/clean-files.txt" > "$RUN_DIR/_clean.txt"
    comm -23 "$RUN_DIR/_all.txt" "$RUN_DIR/_clean.txt" > "$RUN_DIR/_dirty.txt"
    [ -s "$RUN_DIR/_dirty.txt" ] && TARGETS="$(paste -sd, "$RUN_DIR/_dirty.txt")"
  fi
fi

PROMPT="Code-quality audit (CQC kit). Walk target paths, identify critical/high-severity issues across security, correctness, performance, maintainability. Emit one finding per issue with file:line, rule, severity (c/h/m/l), short message. Read-only, no edits."

# ─── Build MCO command ────────────────────────────────────────────
MCO_CMD=(
  "$MCO_BIN" review
  --repo "$(pwd)"
  --prompt "$PROMPT"
  --providers "$PROV_CSV"
  --target-paths "$TARGETS"
  --max-provider-parallelism "$MAX_PARALLEL"
  --stall-timeout "$STALL_TIMEOUT"
  --artifact-base "$RUN_DIR/mco-output"
  --result-mode both
  --save-artifacts
  --json
  --strict-contract
  --task-id "$RUN_ID"
)

echo "${C_BOLD}╭─ cqc-orchestrate v4 (MCO-backed) ──────────────────────────╮${C_RST}"
echo "${C_BOLD}│${C_RST} run-id:    ${C_DIM}$RUN_ID${C_RST}"
echo "${C_BOLD}│${C_RST} scope:     ${C_CYAN}$SCOPE${C_RST}"
echo "${C_BOLD}│${C_RST} providers: ${C_GREEN}$PROV_CSV${C_RST}"
[ "${#SKIPPED[@]}" -gt 0 ] && echo "${C_BOLD}│${C_RST} skipped:   ${C_AMBER}${SKIPPED[*]}${C_RST}"
echo "${C_BOLD}│${C_RST} prefilter: ${PREFILTER_DIR:-<none>} ($CLEAN_COUNT clean files excluded)"
echo "${C_BOLD}│${C_RST} parallel:  $MAX_PARALLEL · stall: ${STALL_TIMEOUT}s"
echo "${C_BOLD}╰─────────────────────────────────────────────────────────────╯${C_RST}"

# Save the planned command for reproducibility.
printf '%q ' "${MCO_CMD[@]}" > "$RUN_DIR/_mco-command.txt"; echo >> "$RUN_DIR/_mco-command.txt"

if [ "$PLAN_ONLY" = "1" ]; then
  echo ""; echo "${C_AMBER}▸ --plan-only: command not executed${C_RST}"
  echo "Command:"; cat "$RUN_DIR/_mco-command.txt"
  exit 0
fi

cat > "$RUN_DIR/_run.json" <<EOF
{"run_id":"$RUN_ID","scope":"$SCOPE","providers":"$PROV_CSV","started_at":"$(date -u +%Y-%m-%dT%H:%M:%SZ)","phase":"running","mode":"mco","max_parallel":$MAX_PARALLEL}
EOF

echo ""; echo "${C_BOLD}▸ Executing MCO…${C_RST}"
SECONDS=0
set +e
"${MCO_CMD[@]}" > "$RUN_DIR/mco-output/result.json" 2> "$RUN_DIR/mco-output/stderr.log"
EXIT=$?
set -e
DUR=$SECONDS

PHASE="done"; [ $EXIT -ne 0 ] && PHASE="failed"
jq --arg now "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson e "$EXIT" --argjson d "$DUR" --arg ph "$PHASE" \
   '. + {completed_at:$now, exit_code:$e, duration_s:$d, phase:$ph}' \
   "$RUN_DIR/_run.json" > "$RUN_DIR/_run.json.tmp" && mv "$RUN_DIR/_run.json.tmp" "$RUN_DIR/_run.json"

echo ""; echo "${C_BOLD}╭─ Final ─────────────────────────────────────────────────────╮${C_RST}"
printf "${C_BOLD}│${C_RST} run-id:   %s\n" "$RUN_ID"
printf "${C_BOLD}│${C_RST} duration: %ds  exit: %d\n" "$DUR" "$EXIT"
printf "${C_BOLD}│${C_RST} reports:  %s/\n" "$RUN_DIR"
echo "${C_BOLD}╰─────────────────────────────────────────────────────────────╯${C_RST}"
exit $EXIT
