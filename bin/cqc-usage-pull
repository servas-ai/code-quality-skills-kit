#!/usr/bin/env python3
"""cqc-usage-pull — pull real usage data from ccusage variants.

Writes ~/.cqc/usage.json. Designed to run on-demand (UI Refresh button) or cron.

Sources:
- @ccusage/codex   → codex tokens + cost (real numbers from JSONL)
- @ccusage/opencode → opencode tokens
- ccusage          → claude tokens (excluded from blocks but recorded)
- gemini           → no tool yet; estimate from session-file count

Output: ~/.cqc/usage.json with shape:
{
  "version": 2,
  "updated_at": "2026-...",
  "by_cli": {
    "codex":    {"today_usd": 2.22, "today_tokens": 1591364, "calls_today": 7,
                 "model_used": "gpt-5.5", "used_pct": 12.3, "raw": {...}},
    "gemini":   {...},
    "opencode": {...},
    "claude":   {...}
  },
  "by_day": {"2026-05-02": {codex:..., ...}},
  "errors": []
}
"""
import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timezone

USAGE_FILE = os.path.expanduser("~/.cqc/usage.json")
BUDGET_FILE = os.path.expanduser("~/.cqc/budget.json")

# Per-CLI quota anchors (rough — refine when caut is added)
QUOTA_ANCHORS = {
    "codex":    {"daily_usd_full": 18.0,  "weekly_usd_full": 100.0},   # ChatGPT plan estimate
    "gemini":   {"daily_calls_full": 100, "weekly_calls_full": 500},   # Free tier estimate
    "opencode": {"daily_tokens_full": 10_000_000},                      # GLM-5.1 unmetered
    "claude":   {"daily_usd_full": 50.0},
}


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def today_key():
    return datetime.now(timezone.utc).strftime("%Y-%m-%d")


def _today_row(daily):
    """Find today's row across multiple ccusage date formats."""
    if not daily: return {}
    today = datetime.now(timezone.utc)
    candidates = [
        today.strftime("%b %d, %Y"),       # "May 02, 2026"
        today.strftime("%b %-d, %Y"),      # "May 2, 2026"
        today.strftime("%Y-%m-%d"),        # "2026-05-02"
        today.strftime("%Y%m%d"),          # "20260502"
    ]
    for row in daily:
        ds = str(row.get("date", ""))
        if any(c == ds or c in ds for c in candidates):
            return row
    # Fallback: assume daily is sorted, take last
    return daily[-1] if daily else {}


def run_json(cmd, timeout=30):
    """Run a command, strip stderr/warnings, parse JSON from first { or [."""
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        out = r.stdout
        if not out.strip():
            return None, f"empty output from {' '.join(cmd[:2])}"
        # Strip leading non-JSON lines (npm warnings etc.)
        idx = out.find("{")
        idx2 = out.find("[")
        if idx2 >= 0 and (idx < 0 or idx2 < idx):
            idx = idx2
        if idx < 0:
            return None, "no JSON found"
        return json.loads(out[idx:]), None
    except subprocess.TimeoutExpired:
        return None, f"timeout {' '.join(cmd[:2])}"
    except Exception as e:
        return None, str(e)


def pull_codex_ratelimits():
    """REAL 5h+weekly % from latest ~/.codex/sessions/**/token_count event."""
    import glob
    files = sorted(glob.glob(os.path.expanduser("~/.codex/sessions/**/*.jsonl"), recursive=True),
                   key=lambda p: os.path.getmtime(p), reverse=True)
    for fp in files[:20]:
        latest = None
        try:
            with open(fp) as f:
                for line in f:
                    try: e = json.loads(line)
                    except Exception: continue
                    if e.get("type") == "event_msg" and (e.get("payload") or {}).get("type") == "token_count":
                        rl = (e["payload"].get("rate_limits") or {})
                        if rl.get("primary") and rl["primary"].get("used_percent") is not None:
                            latest = e
            if latest:
                rl = latest["payload"]["rate_limits"]
                p, s = rl.get("primary") or {}, rl.get("secondary") or {}
                return {
                    "primary":  {"used_percent": p.get("used_percent"),
                                 "window_minutes": p.get("window_minutes"),
                                 "resets_at": p.get("resets_at")},
                    "secondary": {"used_percent": s.get("used_percent"),
                                  "window_minutes": s.get("window_minutes"),
                                  "resets_at": s.get("resets_at")} if s.get("used_percent") is not None else None,
                    "source_ts": latest.get("timestamp"),
                    "source_file": fp,
                }
        except Exception: pass
    return None


def pull_codex():
    """ccusage tokens + JSONL ratelimits (REAL %)"""
    data, err = run_json(["bun", "x", "@ccusage/codex@latest", "daily", "--json"], timeout=60)
    if err: return None, err
    daily = data.get("daily", [])
    today_row = _today_row(daily)
    totals = data.get("totals", {})
    rl = pull_codex_ratelimits()
    return {
        "today_usd":     round(today_row.get("costUSD", 0.0), 4),
        "today_tokens":  today_row.get("totalTokens", 0),
        "model_used":    next(iter(today_row.get("models", {})), None),
        "all_time_usd":  round(totals.get("costUSD", 0.0), 2),
        "all_time_tokens": totals.get("totalTokens", 0),
        "ratelimits":    rl,  # REAL 5h+weekly from sessions
        "raw": {"date": today_row.get("date"), "models": list((today_row.get("models") or {}).keys())},
    }, None


def pull_opencode():
    """bun x @ccusage/opencode@latest daily --json"""
    data, err = run_json(["bun", "x", "@ccusage/opencode@latest", "daily", "--json"], timeout=60)
    if err: return None, err
    daily = data.get("daily", [])
    today_row = _today_row(daily)
    totals = data.get("totals", {})
    return {
        "today_usd":     round(today_row.get("costUSD", 0.0), 4),
        "today_tokens":  today_row.get("totalTokens", 0),
        "model_used":    next(iter(today_row.get("models", {})), None),
        "all_time_tokens": totals.get("totalTokens", 0),
        "raw": {"date": today_row.get("date"), "models": list((today_row.get("models") or {}).keys())},
    }, None


def pull_claude_oauth():
    """REAL email + 5h/weekly utilization from api.anthropic.com (cached 5min on disk)."""
    creds = os.path.expanduser("~/.claude/.credentials.json")
    if not os.path.isfile(creds):
        return None, "credentials.json missing — run `claude /login`"
    try:
        with open(creds) as f: c = json.load(f)
        oa = c.get("claudeAiOauth", {})
        tok = oa.get("accessToken")
        if not tok: return None, "no access token"
        # Cache file
        cache = "/tmp/cqc-claude-oauth-cache.json"
        if os.path.isfile(cache) and (time.time() - os.path.getmtime(cache)) < 300:
            try:
                with open(cache) as f: return json.load(f), None
            except Exception: pass
        # Live profile + usage
        import urllib.request, urllib.error
        out = {"plan": oa.get("subscriptionType"), "rate_limit_tier": oa.get("rateLimitTier"),
               "expires_at_ms": oa.get("expiresAt")}
        for endpoint, key in [("profile", "profile"), ("usage", "usage")]:
            try:
                req = urllib.request.Request(
                    f"https://api.anthropic.com/api/oauth/{endpoint}",
                    headers={"Authorization": f"Bearer {tok}",
                             "anthropic-beta": "oauth-2025-04-20",
                             "User-Agent": "cqc-ui/3.18"})
                with urllib.request.urlopen(req, timeout=10) as r:
                    out[key] = json.loads(r.read().decode())
            except urllib.error.HTTPError as e:
                out[key + "_error"] = f"{e.code} {e.reason}"
                if e.code == 401: out["needs_relogin"] = True
            except Exception as e:
                out[key + "_error"] = str(e)
        # Persist cache
        try:
            with open(cache, "w") as f: json.dump(out, f)
        except Exception: pass
        return out, None
    except Exception as e:
        return None, str(e)


def pull_claude():
    """OAuth profile/usage + ccusage tokens"""
    oauth, err = pull_claude_oauth()
    data, _ = run_json(["bun", "x", "ccusage@latest", "daily", "--json"], timeout=60)
    today_row = _today_row((data or {}).get("daily", []))
    totals = (data or {}).get("totals", {})
    out = {
        "today_usd":     round(today_row.get("costUSD", 0.0), 4),
        "today_tokens":  today_row.get("totalTokens", 0),
        "model_used":    next(iter(today_row.get("models", {})), None),
        "all_time_usd":  round(totals.get("costUSD", 0.0), 2),
    }
    if oauth:
        prof = (oauth.get("profile") or {}).get("account") or {}
        org  = (oauth.get("profile") or {}).get("organization") or {}
        usage= oauth.get("usage") or {}
        out["email"]       = prof.get("email")
        out["full_name"]   = prof.get("full_name")
        out["plan"]        = "claude_max" if prof.get("has_claude_max") else ("claude_pro" if prof.get("has_claude_pro") else oauth.get("plan"))
        out["org_name"]    = org.get("name")
        out["rate_limit_tier"] = org.get("rate_limit_tier")
        out["five_hour"]   = usage.get("five_hour")
        out["seven_day"]   = usage.get("seven_day")
        out["seven_day_sonnet"] = usage.get("seven_day_sonnet")
        out["seven_day_opus"]   = usage.get("seven_day_opus")
        out["needs_relogin"] = oauth.get("needs_relogin", False)
        out["oauth_error"]   = oauth.get("profile_error") or oauth.get("usage_error")
    elif err:
        out["oauth_error"] = err
        out["needs_relogin"] = "missing" in (err or "")
    return out, None


def pull_gemini():
    """No quota API exists (verified). Count today's session files as ROUGH lower-bound only.

    The session-file count is misleading — multi-turn sessions count as 1, and old chats persist.
    Mark this clearly so the dashboard shows "no quota API" instead of fake %.
    """
    chats_dir = os.path.expanduser("~/.gemini/tmp")
    today = today_key()
    sessions_today = 0
    last_model = None
    if os.path.isdir(chats_dir):
        for root, _, files in os.walk(chats_dir):
            for fn in files:
                if not fn.endswith(".json"): continue
                fp = os.path.join(root, fn)
                try:
                    mtime = datetime.fromtimestamp(os.path.getmtime(fp), tz=timezone.utc)
                    if mtime.strftime("%Y-%m-%d") == today:
                        sessions_today += 1
                        try:
                            with open(fp) as f: d = json.load(f)
                            m = d.get("model") or (d.get("config", {}).get("model") if isinstance(d.get("config"), dict) else None)
                            if m: last_model = m
                        except Exception: pass
                except Exception: pass
    # Check oauth_creds expiry for auth status
    oc = os.path.expanduser("~/.gemini/oauth_creds.json")
    needs_relogin = False
    auth_error = None
    if not os.path.isfile(oc):
        needs_relogin = True
        auth_error = "oauth_creds.json missing"
    else:
        try:
            with open(oc) as f: o = json.load(f)
            exp = o.get("expiry_date") or o.get("expiry")
            if exp and exp > 1e10: exp = exp / 1000
            if exp and not o.get("refresh_token"):
                if exp < time.time():
                    needs_relogin = True
                    auth_error = "access token expired AND no refresh token"
        except Exception as e:
            auth_error = str(e)
    return {
        "today_usd":     0.0,
        "today_tokens":  0,
        "sessions_today": sessions_today,
        "calls_today":   None,   # don't fake this
        "model_used":    last_model,
        "needs_relogin": needs_relogin,
        "oauth_error":   auth_error,
        "no_quota_api":  True,
        "raw": {"source": "session file count (ROUGH lower bound, NOT real quota)",
                "note": "Google has no quota API for free-tier OAuth users — see cqc docs."},
    }, None


def compute_used_pct(cli, data):
    """Real % from API where available; quota-anchor estimate elsewhere."""
    if not data: return 0
    if cli == "codex":
        rl = data.get("ratelimits") or {}
        p = (rl.get("primary") or {}).get("used_percent")
        s = (rl.get("secondary") or {}).get("used_percent") if rl.get("secondary") else None
        if p is not None or s is not None:
            return max(p or 0, s or 0)
    if cli == "claude":
        # Real OAuth utilization
        fh = (data.get("five_hour") or {}).get("utilization")
        sd = (data.get("seven_day") or {}).get("utilization")
        if fh is not None or sd is not None:
            return max(fh or 0, sd or 0)
    if cli == "gemini":
        # NO quota API — return 0, dashboard will show "no quota API" instead of bar
        return 0
    if cli == "opencode":
        # GLM is "unmetered" — show token count divided by anchor
        a = QUOTA_ANCHORS.get(cli, {})
        full = a.get("daily_tokens_full", 1) or 1
        return min(100, round(100 * (data.get("today_tokens", 0) / full), 1))
    # Fallback
    a = QUOTA_ANCHORS.get(cli, {})
    full = a.get("daily_usd_full", 1.0) or 1.0
    return min(100, round(100 * (data.get("today_usd", 0.0) / full), 1))


def main():
    os.makedirs(os.path.dirname(USAGE_FILE), exist_ok=True)

    # Load existing
    try:
        with open(USAGE_FILE) as f: prev = json.load(f)
    except Exception:
        prev = {"version": 2, "by_cli": {}, "by_day": {}, "errors": []}

    out = {"version": 2, "updated_at": now_iso(), "by_cli": {}, "by_day": prev.get("by_day", {}), "errors": []}

    pullers = {"codex": pull_codex, "opencode": pull_opencode, "claude": pull_claude, "gemini": pull_gemini}
    for cli, fn in pullers.items():
        t0 = time.time()
        data, err = fn()
        elapsed = round(time.time() - t0, 2)
        if err or not data:
            out["errors"].append({"cli": cli, "error": err or "no data", "elapsed": elapsed})
            # Keep previous
            out["by_cli"][cli] = prev.get("by_cli", {}).get(cli, {})
            continue
        data["used_pct"] = compute_used_pct(cli, data)
        data["pulled_at"] = now_iso()
        data["pull_elapsed_s"] = elapsed
        out["by_cli"][cli] = data

    # Append today to history
    today = today_key()
    out["by_day"][today] = {c: out["by_cli"][c] for c in out["by_cli"]}
    # Trim history to last 30 days
    keys = sorted(out["by_day"].keys())
    if len(keys) > 30:
        for k in keys[:-30]: out["by_day"].pop(k, None)

    tmp = USAGE_FILE + ".tmp"
    with open(tmp, "w") as f: json.dump(out, f, indent=2)
    os.replace(tmp, USAGE_FILE)

    print(json.dumps({
        "ok": True,
        "updated_at": out["updated_at"],
        "by_cli": {c: {"used_pct": d.get("used_pct"), "today_usd": d.get("today_usd"), "model": d.get("model_used")}
                   for c, d in out["by_cli"].items()},
        "errors": out["errors"],
    }, indent=2))


if __name__ == "__main__":
    main()
